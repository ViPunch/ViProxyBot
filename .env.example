# Telegram Bot Token from @BotFather
BOT_TOKEN=

# Telegram Admin IDs (comma-separated numeric IDs from @userinfobot)
ADMIN_IDS=

# Encryption key for secret store (≥16 chars, generated by installer)
ENCRYPTION_KEY=

# Public IP of this VPS
VPS_PUBLIC_IP=

# Public host for access links (domain or IP)
PUBLIC_HOST=

# SSL mode: domain | ip | selfsigned
SSL_MODE=

# Domain for Let's Encrypt (required if SSL_MODE=domain)
DOMAIN=

# Custom certificate paths (required if SSL_MODE=custom)
SSL_CERT_PATH=
SSL_KEY_PATH=

# Protocol ports
HYSTERIA_PORT=
